# Python
.venv/
__pycache__/
*.pyc

# ログ
logs/
*.log

# シークレット・ローカル環境
.env
.env.*

# data/ 配下は原則無視するが、snapshots/ と archive/ は GitHub Actions の差分判定
# （新着/消滅）にスナップショット持ち越しが必須なので追跡する。一時ファイル等は無視。
data/*
!data/snapshots/
!data/archive/

# Claude Code のローカル設定（ユーザー名・絶対パスを含むため公開リポジトリには載せない）
.claude/

# ローカル作業用（ショートカット等）
_work/
